<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for LTBox.app. The USB entitlement lets
  libusb/nusb claim the Qualcomm 9008 (05c6:9008) EDL interface. Its actual
  necessity under the hardened runtime is verified on hardware in plan S7.
  Not sandboxed (no App Store), so no com.apple.security.app-sandbox.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.device.usb</key>
    <true/>
</dict>
</plist>
